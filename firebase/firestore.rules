rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function userCreateIsSafe(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == "user"
        && request.resource.data.accountStatus == "active"
        && request.resource.data.plan == "free_trial"
        && request.resource.data.subscriptionStatus == "trial"
        && request.resource.data.keys().hasOnly([
          "uid", "email", "displayName", "photoURL",
          "createdAt", "updatedAt",
          "onboardingCompleted", "onboarding_completed",
          "trialStartedAt", "trialEndsAt",
          "subscriptionStatus", "plan", "limits", "usage",
          "role", "accountStatus", "consent", "settings"
        ]);
    }

    function userUpdateIsSafe(uid) {
      return isOwner(uid)
        && !changedKeys().hasAny([
          "uid", "email", "role", "accountStatus",
          "plan", "subscriptionStatus", "limits", "billing",
          "trialStartedAt", "trialEndsAt", "createdAt"
        ])
        && changedKeys().hasOnly([
          "displayName", "photoURL", "updatedAt",
          "onboardingCompleted", "onboarding_completed",
          "consent", "settings", "usage"
        ])
        && (
          !changedKeys().hasAny(["usage"])
          || (
            !("usage" in resource.data)
            && request.resource.data.usage.documentCount >= 0
            && request.resource.data.usage.storageBytesUsed >= 0
            && request.resource.data.usage.aiRequestsMonth >= 0
            && request.resource.data.usage.aiTokensUsedMonth >= 0
          )
          || (
            "usage" in resource.data
            && request.resource.data.usage.documentCount >= resource.data.usage.documentCount
            && request.resource.data.usage.storageBytesUsed >= resource.data.usage.storageBytesUsed
            && request.resource.data.usage.aiRequestsMonth >= resource.data.usage.aiRequestsMonth
            && request.resource.data.usage.aiTokensUsedMonth >= resource.data.usage.aiTokensUsedMonth
          )
        );
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if userCreateIsSafe(uid);
      allow update: if userUpdateIsSafe(uid);
      allow delete: if false;

      match /personas/{personaId} {
        allow read, write: if isOwner(uid);
      }

      match /documents/{documentId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && request.resource.data.fileSizeBytes is int
          && request.resource.data.fileSizeBytes <= 20 * 1024 * 1024;
        allow update: if isOwner(uid)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "ownerUid", "downloadURL", "storagePath", "fileSizeBytes"
          ]);
        allow delete: if isOwner(uid);

        match /notes/{noteId} {
          allow read, write: if isOwner(uid);
        }
      }

      match /shares/{shareId} {
        allow read, write: if isOwner(uid);
      }

      match /summaries/{summaryId} {
        allow read, write: if isOwner(uid);
      }

      match /auditLogs/{logId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /aiUsageLogs/{logId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
